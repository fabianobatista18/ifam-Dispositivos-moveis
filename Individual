  const [nome, setNome] = useState("");
  const [email, setEmail] = useState("");
  const [mensagem, setMensagem] = useState("");

  // Função ao clicar no botão
  function cadastrar() {

    if (nome === "" || email === "") {
      Alert.alert("Erro", "Preencha todos os campos!");
