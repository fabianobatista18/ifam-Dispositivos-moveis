        <Text style={styles.textoBotao}>Cadastrar</Text>
      </TouchableOpacity>

      {/* RESULTADO */}
      {mensagem !== "" && (
        <Text style={styles.resultado}>{mensagem}</Text>
      )}

    </View>
  );
}

